<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="color-scheme" content="light">
<title>Lex — pesquisa jurídica com fonte</title>
<style>
:root{
  --paper:#f2f0ea;--ink:#11120f;--line:#d2d0c8;--blue:#2357ff;--green:#0a7a4b;
  --amber:#8a5a00;--red:#8d2418;--white:#fff;--mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
  --sans:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;background:var(--paper);color:var(--ink);font:15px/1.5 var(--sans)}
a{color:inherit}
button,textarea{font:inherit}
.shell{max-width:1480px;margin:auto;border-inline:1px solid var(--line);min-height:100vh}
.top{height:36px;display:flex;align-items:center;justify-content:space-between;padding:0 22px;border-bottom:1px solid var(--line);font:11px var(--mono);text-transform:uppercase;letter-spacing:.08em}
.live{display:inline-flex;align-items:center;gap:8px}.dot{width:7px;height:7px;border-radius:50%;background:#999}.dot.ok{background:var(--green)}
.nav{position:sticky;top:0;z-index:20;display:grid;grid-template-columns:250px 1fr auto;align-items:center;padding:16px 22px;border-bottom:1px solid var(--line);background:rgba(242,240,234,.94);backdrop-filter:blur(14px)}
.brand{text-decoration:none;font-weight:800;font-size:18px}.brand small{display:block;font:10px var(--mono);letter-spacing:.1em;text-transform:uppercase}
.links{display:flex;justify-content:center;gap:26px}.links a{font:11px var(--mono);text-decoration:none;text-transform:uppercase}
.back{background:var(--ink);color:#fff;text-decoration:none;padding:10px 14px;font:11px var(--mono);text-transform:uppercase}
.hero{display:grid;grid-template-columns:210px minmax(0,1fr) 300px;border-bottom:1px solid var(--line)}
.hero>*{padding:30px 22px}.hero>*+*{border-left:1px solid var(--line)}
.eyebrow{font:11px var(--mono);letter-spacing:.1em;text-transform:uppercase;color:#555}
.hero h1{font-size:clamp(42px,5.7vw,78px);line-height:.98;letter-spacing:-.05em;margin:16px 0 22px;max-width:900px}
.hero h1 em{font-style:normal;color:var(--blue)}
.hero p{font-size:18px;max-width:760px;margin:0}
.quote{display:flex;flex-direction:column;justify-content:space-between;gap:30px}.quote blockquote{margin:0;font-size:20px;line-height:1.3}
.signal{height:7px;background:linear-gradient(90deg,var(--blue) 0 42%,#cfe947 42% 67%,var(--ink) 67%)}
.workspace{display:grid;grid-template-columns:250px minmax(0,1fr)}
.sidebar{border-right:1px solid var(--line);padding:22px;min-height:700px}
.sidebar h2{font-size:14px;margin:0 0 16px}.examples{display:grid;gap:8px}
.example{border:1px solid var(--line);background:transparent;text-align:left;padding:11px;cursor:pointer;font:12px/1.35 var(--mono)}
.example:hover{background:#fff}
.side-note{margin-top:26px;font-size:13px;color:#555}
.main{min-width:0}
.search{padding:26px;border-bottom:1px solid var(--line)}
.search label{display:block;margin-bottom:9px;font:11px var(--mono);text-transform:uppercase;letter-spacing:.08em}
.search-row{display:grid;grid-template-columns:1fr 148px;gap:10px}
textarea{width:100%;min-height:108px;resize:vertical;background:#fff;border:1px solid var(--ink);padding:15px}
.submit{border:0;background:var(--blue);color:#fff;cursor:pointer;text-transform:uppercase;font:11px var(--mono);letter-spacing:.06em}
.submit:disabled{opacity:.5}.meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:11px}
.tag{border:1px solid var(--line);background:#fff;padding:5px 8px;font:10px var(--mono);text-transform:uppercase}
.notice{padding:15px 26px;border-bottom:1px solid var(--line);background:#e6edff}
.notice.error{background:#ffe5e1;color:var(--red)}
.output-empty{padding:48px 26px;color:#666}
.result-head{display:grid;grid-template-columns:1fr auto;gap:20px;align-items:end;padding:24px 26px;border-bottom:1px solid var(--line)}
.result-head h2{font-size:28px;line-height:1.05;margin:6px 0 0}.result-head .trace{font:10px var(--mono);text-align:right;color:#666}
.summary{padding:24px 26px;border-bottom:1px solid var(--line);background:#fff}
.summary-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--line);margin-top:18px}
.metric{padding:15px}.metric+.metric{border-left:1px solid var(--line)}
.metric strong{display:block;font-size:24px}.metric span{font:10px var(--mono);text-transform:uppercase;color:#666}
.zero{padding:24px 26px;border-bottom:1px solid var(--line);background:#fff7de}
.zero h3{margin:0 0 8px;font-size:18px}.zero p{margin:0;max-width:850px}
.results{border-bottom:1px solid var(--line)}
.result-card{display:grid;grid-template-columns:170px minmax(0,1fr) 190px;border-top:1px solid var(--line);background:#fff}
.result-card:first-child{border-top:0}.result-card>*{padding:20px}.result-card>*+*{border-left:1px solid var(--line)}
.result-card h3{margin:0 0 10px;font-size:20px;line-height:1.2}.result-card p{margin:0;color:#41413d}
.result-card .type{font:10px var(--mono);text-transform:uppercase;color:#666}
.result-card .org{font:11px var(--mono);text-transform:uppercase}
.result-card .date{margin-top:7px;font-size:12px;color:#666}
.actions{display:grid;gap:8px;align-content:start}.actions a{display:block;text-decoration:none;border:1px solid var(--ink);padding:9px 10px;font:10px var(--mono);text-transform:uppercase}.actions